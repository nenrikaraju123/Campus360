# Copy to .env and fill in. NEVER commit the real .env.
# ---- Database (PostgreSQL) ----
DB_URL=jdbc:postgresql://localhost:5432/campus360
DB_USERNAME=campus360
DB_PASSWORD=campus360

# ---- JWT ----
# Base64-encoded 256-bit (32+ byte) secret. Generate: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-base64-secret-at-least-32-bytes-long
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# ---- Mail (optional in dev; use Mailhog) ----
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# ---- Campus360 Intelligence (OpenAI via Spring AI) ----
# Leave AI_ENABLED=false to run with the offline heuristic fallback (no key needed).
AI_ENABLED=false
OPENAI_API_KEY=not-set
OPENAI_MODEL=gpt-4o-mini

# ---- App ----
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
